@article{Bogan2011,
abstract = {The capital structure of lending institutions has become an increasingly prominent issue in the world of finance. Contemporaneously, Microfinance Institutions (MFIs) have risen to the forefront as invaluable lending institutions in the development process. Since capital constraints have hindered the expansion of microfinance programs and microfinance organizations have had various degrees of sustainability, the question of how best to finance these organizations is a key issue. This paper examines the existing sources of funding for MFIs by geographic region, and explores how changes in capital structure could improve the efficiency and financial sustainability of MFIs. Using panel data, I establish a link between capital structure and key measures of MFI success. Notably, I find causal evidence supporting the assertion that an increased use of grants by large MFIs decreases operational self-sufficiency. (},
author = {Bogan, Vicki},
journal = {forthcoming, The Review of Economics and Statistics},
keywords = {Cross-country,Financing microfinance,Panel,Regulation},
mendeley-tags = {Cross-country,Financing microfinance,Panel,Regulation},
title = {{Capital Structure and Sustainability : An Empirical Study of Microfinance Institutions}},
year = {2011}
}
