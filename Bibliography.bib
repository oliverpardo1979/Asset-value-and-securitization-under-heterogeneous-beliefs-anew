@article{Drugov2010,
abstract = {When people start a new activity, they may not know how good they will be at it and, therefore, must experiment in order to learn. What happens when the experimentation is Önanced by a lender? We show that Önancing experimentation can become harder precisely when experimentation is most valuable, for example, for a longer time horizon and for a lower payo§ of the known activity. Under ex- post competition from alternative lenders, more optimistic prior on the proÖtability of the unknown activity can also make Önancing harder. With projects of variable scale, credit constraints might take the form of larger than optimal initial projects followed by lower than optimal growth rates. The optimal contract, which is ro- bust to self-saving by the borrower, entails endogenous collateral requirements as observed in, e.g., micro-credit schemes.},
author = {Drugov, M and Macchiavello, R},
journal = {Working paper},
keywords = {MF unchecked,Microfinance},
mendeley-tags = {MF unchecked,Microfinance},
title = {{Financing Experimentation}},
year = {2010}
}
