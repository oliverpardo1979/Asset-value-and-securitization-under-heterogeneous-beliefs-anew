@misc{DeMel2008,
abstract = {We use randomized grants to generate shocks to capital stock for a set of Sri Lankan microenterprises. We find the average real return to capital in these enterprises is 4.6\%–5.3\% permonth (55\%–63\% per year), substantially higher than market interest rates. We then examine the heterogeneity of treatment effects. Returns are found to vary with entrepreneurial ability andwith household wealth, but not to vary with measures of risk aversion or uncertainty. Treatment impacts are also significantly larger for enterprises owned by males; indeed, we find no positive return in enterprises owned by females.},
author = {{De Mel}, S and McKenzie, David and Woodruff, C},
booktitle = {Quarterly Journal of Economics},
keywords = {Credit constraints,Empirical,MF Other,Microfinance,RCT,Risk aversion,returns to capital},
