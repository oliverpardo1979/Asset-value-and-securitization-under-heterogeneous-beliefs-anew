@article{Baland2011,
abstract = {This research project aims at complementing the burgeoning RCT literature on the impact of microfinance, thanks to a unique panel database on members and nonmembers of informal credit and saving associations in villages of Jharkhand, India. The data come from an original survey that resembles standard Living Standards Measurement Surveys, which was administered in three waves between 2004 and 2009. While the non-randomized nature of the treatment does not allow straightforward causal inference, its richness and duration permit the observation of a wide-ranging set of long-run evolutions and dynamic mechanisms at the individ- ual, household and village levels. Moreover, the size of the sample allows to analyze interesting village-wide dynamics in villages that started Self-Help Groups (SHGs). Using different sta- tistical techniques, we document changes happening in member and control households, along many different dimensions: participation in financial and labor markets, investments in human or physical capital, vulnerability, consumption, etc. In addition, having data about nonusers both in treated and control villages, we are able to test for endogeneity of the placement of the NGO-sponsored program, as well as the presence of spillovers at the village level. Finally, this last feature also allows using propensity score matching to restrict the comparison of members to would-be members in control villages, in order to identify causal relationships - though causal inference is not the main focus of this research.},
author = {Baland, Jean-Marie and Demont, Timoth\'{e}e and Somanathan, Rohini},
journal = {mimeo},
keywords = {Empirical,Experimental,Group lending,Joint Liability,Microfinance,Panel Survey,SHG},
mendeley-tags = {Empirical,Experimental,Group lending,Joint Liability,Microfinance,Panel Survey,SHG},
pages = {1--35},
title = {{Microfinance mechanisms : evidence from observational panel data about}},
year = {2011}
}
