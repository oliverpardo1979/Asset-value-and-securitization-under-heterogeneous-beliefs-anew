@article{SL,
abstract = {Many children and youths in countries throughout the world begin having sexual intercourse at early ages. Most, however, do not use contraception. Unprotected sexual intercourse therefore leads to unwanted pregnancy, childbirth, and infection with sexually transmitted diseases. Pregnancy and childbirth among girls in their early teens hold relatively higher risk of medical complications or death than for older girls and women. Young girls may also resort to illegal abortions, receive inadequate medical care, or drop out of school before completion. Comprehensive and relevant sex and health education programs including contraceptive service targeted to all children before they become sexually active could go a long way toward reducing some of these negative consequences of unprotected adolescent sexual activity. Such education and services, however, remain controversial in many societies. Most school systems fail to meet the sexual health education needs of youth and children. The authors stress the need for all people to rationally accept that large numbers of adolescents are having unprotected sexual intercourse in societies and populations around the world, and offer the information, understanding, and contraceptive services they so urgently need. They further argue for the expansion of education and employment opportunities for girls, and the elimination of traditional child marriage and female genital mutilation. Private organizations have pioneered a variety of strategies to reach youth, but the scope of their efforts needs to be expanded. These views and supporting statistics are provided in a question and answer format. The paper also considers lessons learned in developing programs for youth and profiles several programs from developing countries.},
author = {Koontz, SL and Conly, SR},
journal = {Population Action International},
keywords = {AIDS,AIDS Prevention,Adolescent Pregnancy,Adolescents,Age Factors,Behavior,Contraception,Demographic Factors,Developing Countries,Diseases,Economic Factors,Education,Family Planning,Fertility,HIV Infections,HIV Prevention,Health,Health Education,Infections,Needs,Organization and Administration,Population,Population At Risk,Population Characteristics,Population Dynamics,Premarital Sex Behavior,Programs,Reproductive Behavior,Reproductive Health,Reproductive Tract Infections,Research Methodology,School-Based Services,Sex Behavior,Sex Education,Sexually Transmitted Disease Prevention,Sexually Transmitted Diseases,Viral Diseases,Youth},
language = {English},
publisher = {Washington, D.C., Population Action International, 1994 Mar.},
title = {{Youth at risk: meeting the sexual health needs of adolescents}},
url = {http://www.popline.org/node/277986},
year = {1994}
