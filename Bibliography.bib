@article{Wydick1999,
abstract = {The success of group lending in developing countries has been attributed to the ability of the institution to mitigate asymmetric information problems in credit markets. Previous research has offered a number of explanations for this phenomenon: social ties between borrowing group members, internal group pressure to repay loans, and peer monitoring. This research presents empirical tests on borrowing group data from Guatemala which indicate that peer monitoring significantly effects borrowing group performance through stimulating intragroup insurance. Group pressure is found to have a small effect in deterring moral hazard, while the effect of social ties among members is statistically insignificant.},
annote = {Looking at summary stats;
        
(1) more difficult to put pressure/ sanctions on members in rural areas --> this makes them more effective in reducing "moral hazard" - loan misuse
--> more likely to be friends in rural areas
        
(2) members in rural areas more likely to have same occupation 
        
(3) MFI uses a form of IJ as members of group can be expelled, these wont have access to credit anymore .. but stem group stays intact},
author = {Wydick, Bruce},
doi = {10.1111/1468-0297.00457},
issn = {0013-0133},
journal = {The Economic Journal},
keywords = {Empirical,Group Lending,Guatemala,Microfinance,Monitoring,Repayment,Social capital,Social sanctions},
mendeley-tags = {Empirical,Group Lending,Microfinance,Monitoring,Repayment,Social capital},
month = jul,
number = {457},
pages = {463--475},
title = {{Can Social Cohesion be Harnessed to Repair Market Failures? Evidence from Group Lending in Guatemala}},
