title = {{Across-Product Versus Within-Product Specialization in International Trade}},
url = {http://qje.oxfordjournals.org.ezaccess.libraries.psu.edu/content/119/2/647$\backslash$nhttp://qje.oxfordjournals.org.ezaccess.libraries.psu.edu/content/119/2/647.full.pdf$\backslash$nhttp://qje.oxfordjournals.org.ezaccess.libraries.psu.edu/content/119/2/647.short},
