@article{Aniket2007,
abstract = {The paper examines the pros and cons of lending sequentially to a group, composed of two wealthless individuals who are jointly liable for each other’s project outcome. Sequential lending entails lending to one borrower per period, with the proviso that the second bor- rower’s loan is contingent on the first borrower’s project succeeding. We show that in a moral hazard environment, where the borrowers can influence their peer’s effort through costly monitoring, the borrowers are allocated smaller rents in sequential as compared to simultaneous group lending. Conversely, the lender’s capital is less productive in se- quential as compared to simultaneous lending. Thus, for a sufficiently efficient peer monitoring technology a greater range of projects is fea- sible under sequential lending.},
author = {Aniket, K},
journal = {ESE Discussion Paper},
keywords = {Joint Liability,MF Group Lending,Microfinance,Monitoring,Moral Hazard,Sequential lending,Theory},
