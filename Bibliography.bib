@article{deQuidt2011,
abstract = {This paper contrasts the behaviour of lenders with market power with competi- tive lenders in an environment where borrowers are collateral-poor but lenders can use implicit or explicit joint liability, leveraging the social capital that borrowers might have among themselves. We show that joint liability is preferred by borrow- ers compared to standard loan contracts, and also by the monopolist when he can earn sufficiently high rents from the borrowers’ social capital. We consider policy implications and several extensions, including investments in social capital by the borrowers and the lender and how they are affected by the lending arrangements, and allowing lenders to use coercive methods.},
author = {de Quidt, Jonathan and Fetzer, Thiemo Rene and Ghatak, Maitreesh},
journal = {mimeo},
title = {{Microfinance with a Monopoly Lender}},
year = {2011}
}
@article{Chowdhury2005,
abstract = {We develop a simple model of group-lending based on peer monitoring and moral hazard. We find that, in the absence of sequential financing or lender monitoring, group-lending schemes may involve under-monitoring with the borrowers investing in undesirable projects. Moreover, under certain parameter configurations, group-lending schemes involving either sequential financing, or a combination of lender monitoring and joint liability are feasible. In fact, group-lending schemes with sequential financing may succeed even in the absence of joint liability, though the repayment rate will be lower. In the absence of joint liability, however, group-lending with lender monitoring is unlikely to be feasible.},
author = {Chowdhury, P R},
journal = {Journal of Development Economics},
keywords = {Group lending,MF Group Lending,Microfinance,Monitoring,Moral Hazard,Repayment,Sequential lending,Social ties,Theory},
mendeley-tags = {Group lending,MF Group Lending,Microfinance,Monitoring,Moral Hazard,Repayment,Sequential lending,Social ties,Theory},
number = {2},
pages = {415--439},
title = {{Group-lending: Sequential financing, lender monitoring and joint liability}},
url = {http://linkinghub.elsevier.com/retrieve/pii/S0304387805000143},
volume = {77},
year = {2005}
}
