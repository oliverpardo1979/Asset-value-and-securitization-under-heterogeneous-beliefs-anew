@article{Mcintosh2009,
abstract = {We present the results of a new laboratory experiment designed to mimic the ways in which credit bureaus will alter microfinance markets. Where loans are taken in groups, bureaus can build reputations for borrowers at the group or the individual level, and the optimal contract is not obvious. In a modified public good game with ejection and re-assignment played by Guatemalan microentrepreneurs, we find the use of group reputation to be effective in increasing contributions. Given the costs of transitioning microfinance bureaus to the sharing of individual information, our results suggest that this change would not be cost effective.},
