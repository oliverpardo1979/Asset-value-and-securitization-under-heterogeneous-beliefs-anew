@article{Lensink2009,
abstract = {Nearly one of every five Microfinance Institutions (MFIs) refuses to follow policy recommendations to specialise in microfinance only. Instead they argue that overcoming poverty requires more than access to capital and therefore provide social services like literacy training, health services or business training alongside microfinance. In this paper we test whether ‘plus’ MFIs differ from the specialist MFIs. The findings indicate that ‘plus’ providers are NGOs, unregulated by banking authorities and mainly practice village banking methodologies. In line with the hypothesis ‘plus’ providers have lower financial results compared to specialist MFIs. ‘Plus’ MFIs do however reach out to poorer customers and more female customers compared to their specialised peers.},
author = {Lensink, Robert and Mersland, Roy},
journal = {mimeo},
keywords = {Empirical,Microfinance,Mission drift,Outreach,Regulation,Village banking},
