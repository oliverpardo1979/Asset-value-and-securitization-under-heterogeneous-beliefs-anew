keywords = {Agriculture,Biodiversity,Conservation of Natural Resources,Conservation of Natural Resources: methods,Conservation of Natural Resources: statistics \& nu,Conservation of Natural Resources: trends,Data Interpretation, Statistical,Ecosystem,Geography,Italy,Socioeconomic Factors},
