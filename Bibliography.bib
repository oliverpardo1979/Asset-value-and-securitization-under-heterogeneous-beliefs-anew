@article{Basu2010,
abstract = {When individuals have time-inconsistent preferences, they value commitment savings products. This paper studies the provision of commitment by informal banking institutions. I seek to answer the following questions: when will commit- ment be offered, and when it is offered will it raise consumer welfare? Since a consumer is subject to temptation in the period that he signs a contract, banks might exploit his temptation even as they help him to commit for the future. First, I find that pure commitment savings will reduce a consumer’s welfare relative to autarky if he is moderately time-inconsistent. Second, I show that the ability of banks to enforce loan contracts can result in the elimination of pure commitment saving and a further reduction in welfare. Third, I show how there could be zero takeup of a nonprofit NGO’s provision of commitment if there is competition from a moneylender. However, despite zero takeup, the NGO’s offer will serve to improve welfare by forcing moneylenders to lower their interest rates.},
author = {Basu, Karna},
journal = {mimeo},
keywords = {Savings,Theoretical,commitment,hyperbolic discounting},
mendeley-tags = {Savings,Theoretical,commitment,hyperbolic discounting},
pages = {1--29},
title = {{Commitment Savings in Informal Banking Markets : Implications for Takeup and Welfare}},
year = {2010}
}
