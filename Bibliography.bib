@article{Genicot2006,
abstract = {In a credit market with enforcement constraints, we study the effects of a change in the outside options of a potential defaulter on the terms of the credit contract, as well as on borrower payoffs. The results crucially depend on the allocation of bbargaining powerQ between the borrower and the lender. We prove that there is a crucial threshold of relative weights such that if the borrower has power that exceeds this threshold, her expected utility must go up whenever her outside options come down. But if the borrower has less power than this threshold, her expected payoff must come down with her outside options. In the former case a deterioration in outside options brought about, say, by better enforcement, must create a Lorenz improvement in state-contingent consumption. In particular, borrower consumption rises in all bbadQ states in which loans are taken. In the latter case, in contrast, the borrower’s consumption must decline, at least for all the bad states. These disparate findings within a single model permit us to interpret existing literature on credit markets in a unified way. D 2006 Elsevier B.V. All rights reserved.},
author = {Genicot, Garance and Ray, Debraj},
doi = {10.1016/j.jdeveco.2006.01.006},
issn = {03043878},
journal = {Journal of Development Economics},
keywords = {Bargaining power,Enforcement,Enforcement constraints,Microfinance,Outside options,Theoretical,bargaining power,courts,credit markets,enforcement},
mendeley-tags = {Bargaining power,Enforcement,Enforcement constraints,Microfinance,Outside options,Theoretical},
month = apr,
number = {2},
pages = {398--412},
title = {{Bargaining power and enforcement in credit markets}},
url = {http://linkinghub.elsevier.com/retrieve/pii/S0304387806000113},
volume = {79},
year = {2006}
}
